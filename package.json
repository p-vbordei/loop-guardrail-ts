{
  "name": "@p-vbordei/loop-guardrail",
  "version": "1.0.0",
  "description": "Sliding-window tool-call loop guardrails for LLM agents",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "llm",
    "agent",
    "guardrails",
    "loop-detection",
    "tool-calling",
    "ai-agents"
  ],
  "author": {
    "name": "Vlad Bordei",
    "email": "bordeivlad@gmail.com",
    "url": "https://github.com/p-vbordei"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/p-vbordei/loop-guardrail-ts.git"
  },
  "bugs": {
    "url": "https://github.com/p-vbordei/loop-guardrail-ts/issues"
  },
  "homepage": "https://github.com/p-vbordei/loop-guardrail-ts#readme",
  "engines": {
    "node": ">=20",
    "npm": ">=8"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  }
}
